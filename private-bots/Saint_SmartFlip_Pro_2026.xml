<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="tp">TakeProfit</variable>
    <variable id="sl">StopLoss</variable>
    <variable id="stake">Stake</variable>
    <variable id="loss_streak">LossStreak</variable>
    <variable id="mg">Martingale</variable>
    <variable id="init_stake">InitialStake</variable>
    <variable id="trade_side">TradeSide</variable>
    <variable id="max_stake">MaxStake</variable>
    <variable id="max_loss_streak">MaxLossStreak</variable>
    <variable id="flip_counter">FlipCounter</variable>
  </variables>

  <block type="trade_definition" id="trade_def" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ75V</field>
        <next>
          <block type="trade_definition_tradetype" id="tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">evenodd</field>
            <next>
              <block type="trade_definition_contracttype" id="contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="restart_buy_sell" collapsed="true" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="restart_error" collapsed="true" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="set_tp">
        <field name="VAR" id="tp">TakeProfit</field>
        <value name="VALUE">
          <block type="math_number" id="tp_n"><field name="NUM">3</field></block>
        </value>
        <next>
          <block type="variables_set" id="set_sl">
            <field name="VAR" id="sl">StopLoss</field>
            <value name="VALUE">
              <block type="math_number" id="sl_n"><field name="NUM">3</field></block>
            </value>
            <next>
              <block type="variables_set" id="set_mg">
                <field name="VAR" id="mg">Martingale</field>
                <value name="VALUE">
                  <block type="math_number" id="mg_n"><field name="NUM">1.7</field></block>
                </value>
                <next>
                  <block type="variables_set" id="set_init_stake">
                    <field name="VAR" id="init_stake">InitialStake</field>
                    <value name="VALUE">
                      <block type="math_number" id="is_n"><field name="NUM">0.35</field></block>
                    </value>
                    <next>
                      <block type="variables_set" id="set_stake">
                        <field name="VAR" id="stake">Stake</field>
                        <value name="VALUE">
                          <block type="math_number" id="s_n"><field name="NUM">0.35</field></block>
                        </value>
                        <next>
                          <block type="variables_set" id="set_max_stake">
                            <field name="VAR" id="max_stake">MaxStake</field>
                            <value name="VALUE">
                              <block type="math_number" id="ms_n"><field name="NUM">0.8</field></block>
                            </value>
                            <next>
                              <block type="variables_set" id="set_loss_streak" collapsed="true">
                                <field name="VAR" id="loss_streak">LossStreak</field>
                                <value name="VALUE">
                                  <block type="math_number" id="ls_n"><field name="NUM">0</field></block>
                                </value>
                                <next>
                                  <block type="variables_set" id="set_max_loss_streak" collapsed="true">
                                    <field name="VAR" id="max_loss_streak">MaxLossStreak</field>
                                    <value name="VALUE">
                                      <block type="math_number" id="mls_n"><field name="NUM">4</field></block>
                                    </value>
                                    <next>
                                      <block type="variables_set" id="set_trade_side" collapsed="true">
                                        <field name="VAR" id="trade_side">TradeSide</field>
                                        <value name="VALUE">
                                          <block type="text" id="ts_txt"><field name="TEXT">DIGITEVEN</field></block>
                                        </value>
                                        <next>
                                          <block type="variables_set" id="set_flip_counter" collapsed="true">
                                            <field name="VAR" id="flip_counter">FlipCounter</field>
                                            <value name="VALUE">
                                              <block type="math_number" id="fc_n"><field name="NUM">0</field></block>
                                            </value>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="trade_options" collapsed="true">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="false"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <shadow type="math_number_positive" id="dur"><field name="NUM">1</field></shadow>
        </value>
        <value name="AMOUNT">
          <shadow type="math_number_positive" id="amt"><field name="NUM">0.35</field></shadow>
          <block type="variables_get" id="stake_get">
            <field name="VAR" id="stake">Stake</field>
          </block>
        </value>
      </block>
    </statement>
  </block>

  <block type="after_purchase" id="after" x="714" y="60">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="if_win_loss">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="is_win" collapsed="true">
            <field name="CHECK_RESULT">win</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="win_stake_reset" collapsed="true">
            <field name="VAR" id="stake">Stake</field>
            <value name="VALUE">
              <block type="variables_get" id="init_get">
                <field name="VAR" id="init_stake">InitialStake</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="win_loss_reset" collapsed="true">
                <field name="VAR" id="loss_streak">LossStreak</field>
                <value name="VALUE">
                  <block type="math_number" id="zero_w"><field name="NUM">0</field></block>
                </value>
                <next>
                  <block type="variables_set" id="win_flip_reset" collapsed="true">
                    <field name="VAR" id="flip_counter">FlipCounter</field>
                    <value name="VALUE">
                      <block type="math_number" id="fc_zero_w"><field name="NUM">0</field></block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="math_change" id="loss_inc" collapsed="true">
            <field name="VAR" id="loss_streak">LossStreak</field>
            <value name="DELTA">
              <shadow type="math_number" id="one"><field name="NUM">1</field></shadow>
            </value>
            <next>
              <block type="math_change" id="flip_inc" collapsed="true">
                <field name="VAR" id="flip_counter">FlipCounter</field>
                <value name="DELTA">
                  <shadow type="math_number" id="one_fc"><field name="NUM">1</field></shadow>
                </value>
                <next>
                  <block type="controls_if" id="max_loss_guard">
                    <value name="IF0">
                      <block type="logic_compare" id="streak_too_high" collapsed="true">
                        <field name="OP">GTE</field>
                        <value name="A">
                          <block type="variables_get" id="streak_now">
                            <field name="VAR" id="loss_streak">LossStreak</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="variables_get" id="max_streak_b">
                            <field name="VAR" id="max_loss_streak">MaxLossStreak</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="text_print" id="max_streak_print" editable="false">
                        <value name="TEXT">
                          <shadow type="text" id="max_streak_msg">
                            <field name="TEXT">!! 4 LOSSES IN A ROW - TEAM.SAINTFX E/O PRO PROTECTED YOUR ACCOUNT !!</field>
                          </shadow>
                        </value>
                        <next>
                          <block type="variables_set" id="max_streak_stop" collapsed="true">
                            <field name="VAR" id="stake">Stake</field>
                            <value name="VALUE">
                              <block type="logic_null" id="max_streak_null"></block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <next>
                      <block type="variables_set" id="loss_mg" collapsed="true">
                        <field name="VAR" id="stake">Stake</field>
                        <value name="VALUE">
                          <block type="math_arithmetic" id="mul_stake">
                            <field name="OP">MULTIPLY</field>
                            <value name="A">
                              <block type="variables_get" id="stake_now">
                                <field name="VAR" id="stake">Stake</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="mg_now">
                                <field name="VAR" id="mg">Martingale</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <next>
                          <block type="controls_if" id="max_stake_guard">
                            <value name="IF0">
                              <block type="logic_compare" id="stake_too_high" collapsed="true">
                                <field name="OP">GT</field>
                                <value name="A">
                                  <block type="variables_get" id="stake_guard_a">
                                    <field name="VAR" id="stake">Stake</field>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="variables_get" id="stake_guard_b">
                                    <field name="VAR" id="max_stake">MaxStake</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                            <statement name="DO0">
                              <block type="text_print" id="max_stake_print" editable="false">
                                <value name="TEXT">
                                  <shadow type="text" id="max_stake_msg">
                                    <field name="TEXT">[ MAX STAKE REACHED - RESETTING TO INITIAL STAKE ]</field>
                                  </shadow>
                                </value>
                                <next>
                                  <block type="variables_set" id="guard_reset_stake" collapsed="true">
                                    <field name="VAR" id="stake">Stake</field>
                                    <value name="VALUE">
                                      <block type="variables_get" id="guard_init">
                                        <field name="VAR" id="init_stake">InitialStake</field>
                                      </block>
                                    </value>
                                    <next>
                                      <block type="variables_set" id="guard_reset_loss" collapsed="true">
                                        <field name="VAR" id="loss_streak">LossStreak</field>
                                        <value name="VALUE">
                                          <block type="math_number" id="zero2"><field name="NUM">0</field></block>
                                        </value>
                                        <next>
                                          <block type="variables_set" id="guard_reset_flip" collapsed="true">
                                            <field name="VAR" id="flip_counter">FlipCounter</field>
                                            <value name="VALUE">
                                              <block type="math_number" id="fc_zero2"><field name="NUM">0</field></block>
                                            </value>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </statement>
                            <next>
                              <block type="controls_if" id="flip_every_two">
                                <value name="IF0">
                                  <block type="logic_compare" id="flip_counter_gte2" collapsed="true">
                                    <field name="OP">GTE</field>
                                    <value name="A">
                                      <block type="variables_get" id="fc_get">
                                        <field name="VAR" id="flip_counter">FlipCounter</field>
                                      </block>
                                    </value>
                                    <value name="B">
                                      <block type="math_number" id="two_cmp"><field name="NUM">2</field></block>
                                    </value>
                                  </block>
                                </value>
                                <statement name="DO0">
                                  <block type="variables_set" id="reset_flip_counter" collapsed="true">
                                    <field name="VAR" id="flip_counter">FlipCounter</field>
                                    <value name="VALUE">
                                      <block type="math_number" id="fc_reset"><field name="NUM">0</field></block>
                                    </value>
                                    <next>
                                      <block type="controls_if" id="flip_side">
                                        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                                        <value name="IF0">
                                          <block type="logic_compare" id="if_even" collapsed="true">
                                            <field name="OP">EQ</field>
                                            <value name="A">
                                              <block type="variables_get" id="ts_get">
                                                <field name="VAR" id="trade_side">TradeSide</field>
                                              </block>
                                            </value>
                                            <value name="B">
                                              <block type="text" id="txt_even"><field name="TEXT">DIGITEVEN</field></block>
                                            </value>
                                          </block>
                                        </value>
                                        <statement name="DO0">
                                          <block type="text_print" id="flip_to_odd_print" editable="false">
                                            <value name="TEXT">
                                              <shadow type="text" id="flip_odd_msg">
                                                <field name="TEXT">[ 2 LOSSES - FLIPPING TO ODD ]</field>
                                              </shadow>
                                            </value>
                                            <next>
                                              <block type="variables_set" id="set_odd" collapsed="true">
                                                <field name="VAR" id="trade_side">TradeSide</field>
                                                <value name="VALUE">
                                                  <block type="text" id="txt_odd"><field name="TEXT">DIGITODD</field></block>
                                                </value>
                                              </block>
                                            </next>
                                          </block>
                                        </statement>
                                        <statement name="ELSE">
                                          <block type="text_print" id="flip_to_even_print" editable="false">
                                            <value name="TEXT">
                                              <shadow type="text" id="flip_even_msg">
                                                <field name="TEXT">[ 2 LOSSES - FLIPPING TO EVEN ]</field>
                                              </shadow>
                                            </value>
                                            <next>
                                              <block type="variables_set" id="set_even" collapsed="true">
                                                <field name="VAR" id="trade_side">TradeSide</field>
                                                <value name="VALUE">
                                                  <block type="text" id="txt_even2"><field name="TEXT">DIGITEVEN</field></block>
                                                </value>
                                              </block>
                                            </next>
                                          </block>
                                        </statement>
                                      </block>
                                    </next>
                                  </block>
                                </statement>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <next>
          <block type="controls_if" id="tp_sl">
            <mutation xmlns="http://www.w3.org/1999/xhtml" elseif="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="tp_cmp" collapsed="true">
                <field name="OP">GTE</field>
                <value name="A">
                  <block type="total_profit" id="profit_a"></block>
                </value>
                <value name="B">
                  <block type="variables_get" id="profit_b">
                    <field name="VAR" id="tp">TakeProfit</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="text_print" id="tp_print" editable="false">
                <value name="TEXT">
                  <shadow type="text" id="tp_msg">
                    <field name="TEXT">$ TAKE PROFIT HIT - BANK IT AND REST !</field>
                  </shadow>
                </value>
                <next>
                  <block type="variables_set" id="tp_stop" collapsed="true">
                    <field name="VAR" id="stake">Stake</field>
                    <value name="VALUE">
                      <block type="logic_null" id="tp_null"></block>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
            <value name="IF1">
              <block type="logic_compare" id="sl_cmp" collapsed="true">
                <field name="OP">LTE</field>
                <value name="A">
                  <block type="total_profit" id="sl_a"></block>
                </value>
                <value name="B">
                  <block type="math_single" id="neg_sl">
                    <field name="OP">NEG</field>
                    <value name="NUM">
                      <block type="variables_get" id="sl_b">
                        <field name="VAR" id="sl">StopLoss</field>
                      </block>
                    </value>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO1">
              <block type="text_print" id="sl_print" editable="false">
                <value name="TEXT">
                  <shadow type="text" id="sl_msg">
                    <field name="TEXT">! STOP LOSS HIT - WALK AWAY - NO REVENGE TRADING !</field>
                  </shadow>
                </value>
                <next>
                  <block type="variables_set" id="sl_stop" collapsed="true">
                    <field name="VAR" id="stake">Stake</field>
                    <value name="VALUE">
                      <block type="logic_null" id="sl_null"></block>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="trade_again" id="trade_again"></block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <block type="before_purchase" id="before" deletable="false" x="0" y="1100">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="controls_if" id="side_picker">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="logic_compare" id="side_is_even" collapsed="true">
            <field name="OP">EQ</field>
            <value name="A">
              <block type="variables_get" id="ts_get2">
                <field name="VAR" id="trade_side">TradeSide</field>
              </block>
            </value>
            <value name="B">
              <block type="text" id="txt_even3"><field name="TEXT">DIGITEVEN</field></block>
            </value>
          </block>
        </value>
        <statement name="DO0">
          <block type="purchase" id="buy_even">
            <field name="PURCHASE_LIST">DIGITEVEN</field>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="purchase" id="buy_odd">
            <field name="PURCHASE_LIST">DIGITODD</field>
          </block>
        </statement>
      </block>
    </statement>
  </block>
</xml>
